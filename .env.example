# =========================================================
# Telegram
# =========================================================
TELEGRAM_BOT_TOKEN=1234567890:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Comma-separated Chat-IDs, die den Bot nutzen duerfen (Sicherheits-Whitelist)
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# =========================================================
# Bexio
# =========================================================
BEXIO_API_TOKEN=dein-bexio-personal-access-token
BEXIO_API_BASE_URL=https://api.bexio.com

# =========================================================
# Supabase
# =========================================================
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_STORAGE_BUCKET=invoices

# =========================================================
# Google Gemini
# =========================================================
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.5-flash

# =========================================================
# App Settings
# =========================================================
LOG_LEVEL=INFO
ENVIRONMENT=development

# =========================================================
# IMAP Inbox-Scan (Hostpoint)
# Bot pollt das Postfach und schickt Belege durch die gleiche
# Pipeline wie Telegram-Uploads. Filtert auf Attachment + Keywords
# in Subject ODER Body.
# =========================================================
IMAP_ENABLED=false
IMAP_HOST=imap.mail.hostpoint.ch
IMAP_PORT=993
IMAP_USER=info@deinedomain.ch
IMAP_PASSWORD=app-spezifisches-passwort
IMAP_FOLDER=INBOX
IMAP_POLL_INTERVAL_SECONDS=60
# Case-insensitive Regex - matcht wenn Subject ODER Body eines der
# Keywords enthaelt UND mind. ein PDF/Bild-Attachment vorhanden ist
IMAP_KEYWORDS_REGEX=rechnung|invoice|quittung|beleg|gutschrift|kreditrechnung|bill|receipt|fattura|facture
# Optional: Telegram-Chat-ID an die IMAP-Treffer geschickt werden.
# Leer lassen = erste aus TELEGRAM_ALLOWED_CHAT_IDS
TELEGRAM_NOTIFY_CHAT_ID=
