# Supabase - selbe Projekt wie der Python-Bot
# Public anon-key (NICHT service-role) - die Web-App nutzt RLS fuer
# Multi-Tenant-Sicherheit, kein Service-Role hier.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-Only Service-Role-Key fuer Reads bevor RLS aktiv ist (Phase B
# Demo-Modus). NIEMALS mit NEXT_PUBLIC_ prefixen - waere im Browser
# sichtbar. Dieser Key ist im Bot bereits gesetzt - kopiere ihn aus
# der Python-.env oder Railway-Variables.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Storage-Bucket fuer Beleg-PDFs (selbe wie der Python-Bot)
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=invoices

# Display-Settings
NEXT_PUBLIC_APP_NAME="Bexio AI Workspace"
